{
  "name": "json-schema-preview",
  "displayName": "json-schema-preview",
  "description": "Preview JSON Schema documents inside VSCode.",
  "version": "0.1.0",
  "galleryBanner": {
    "color": "#4a4a4a",
    "theme": "dark"
  },
  "license": "MIT",
  "icon": "resources/icon.png",
  "publisher": "samdidos",
  "author": {
    "name": "Samuel Cardinal",
    "url": "https://github.com/samdidos"
  },
  "bugs": {
    "url": "https://github.com/samdidos/vscode-json-schema-preview/issues"
  },
  "homepage": "https://github.com/samdidos/vscode-json-schema-preview/blob/master/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/samdidos/vscode-json-schema-preview.git"
  },
  "engines": {
    "vscode": "^1.96.0",
    "node": ">=22"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:yml",
    "onLanguage:yaml",
    "onLanguage:json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsonschema.edit",
        "title": "JSON Schema: Edit (visual)",
        "icon": "$(edit)"
      },
      {
        "command": "jsonschema.preview",
        "title": "JSON Schema: Preview",
        "icon": {
          "light": "resources/icons/open-preview_black.svg",
          "dark": "resources/icons/open-preview_white.svg"
        }
      },
      {
        "command": "jsonschema.configure",
        "title": "JSON Schema: Configure Preview",
        "icon": "$(gear)"
      },
      {
        "command": "jsonschema.openConfig",
        "title": "JSON Schema: Open Config File",
        "icon": "$(file-code)"
      },
      {
        "command": "jsonschema.bindToCurrentFile",
        "title": "JSON Schema: Bind Schema to This File"
      },
      {
        "command": "jsonschema.validateFile",
        "title": "JSON Schema: Validate This File",
        "icon": "$(pass)"
      },
      {
        "command": "jsonschema.inferSchema",
        "title": "JSON Schema: Generate Schema from This File",
        "icon": "$(wand)"
      }
    ],
    "configuration": {
      "title": "JSON Schema Preview",
      "properties": {
        "jsonschema.preview.autoOpen": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Automatically open the preview panel when a JSON Schema file is opened or becomes the active editor."
        },
        "jsonschema.preview.liveUpdate": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Refresh the preview as you type (debounced). The preview panel must already be open."
        },
        "jsonschema.preview.liveUpdateDelay": {
          "type": "number",
          "default": 1500,
          "minimum": 500,
          "markdownDescription": "Milliseconds to wait after the last keystroke before the live preview refreshes."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "when": "(resourceLangId == json || resourceLangId == yaml) && jsonschema.isJsonSchema",
          "command": "jsonschema.edit",
          "group": "navigation@1"
        },
        {
          "when": "(resourceLangId == json || resourceLangId == yaml) && jsonschema.isJsonSchema",
          "command": "jsonschema.preview",
          "group": "navigation@2"
        },
        {
          "when": "(resourceLangId == json || resourceLangId == yaml) && jsonschema.isJsonSchema",
          "command": "jsonschema.configure",
          "group": "navigation@3"
        },
        {
          "when": "resourceLangId == json || resourceLangId == yaml",
          "command": "jsonschema.validateFile",
          "group": "navigation@4"
        },
        {
          "when": "resourceLangId == json || resourceLangId == yaml",
          "command": "jsonschema.inferSchema",
          "group": "navigation@5"
        }
      ],
      "commandPalette": [
        {
          "command": "jsonschema.edit"
        },
        {
          "command": "jsonschema.preview"
        },
        {
          "command": "jsonschema.configure"
        },
        {
          "command": "jsonschema.openConfig"
        },
        {
          "command": "jsonschema.bindToCurrentFile"
        },
        {
          "command": "jsonschema.validateFile"
        },
        {
          "command": "jsonschema.inferSchema"
        }
      ],
      "editor/context": [],
      "keybindings": []
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint",
    "test": "tsc -p tsconfig.test.json && c8 mocha --ui tdd --require ./out/test/mocks/setup.js 'out/test/unit/**/*.test.js'",
    "test:coverage": "npm test && node scripts/check-coverage.js",
    "generate:assets": "",
    "bump:version": "npm --no-git-tag-version --allow-same-version version $VERSION"
  },
  "c8": {
    "reporter": [
      "text",
      "json-summary"
    ],
    "include": [
      "out/**/*.js"
    ],
    "exclude": [
      "out/test/**",
      "out/python.js",
      "out/SchemaEditorPanel.js",
      "out/ConfigWebPanel.js",
      "out/ValidationManager.js"
    ],
    "all": true
  },
  "overrides": {
    "diff": ">=9.0.0",
    "serialize-javascript": ">=7.0.5"
  },
  "devDependencies": {
    "@json-editor/json-editor": "^1.17.0",
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "c8": "^11.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.4.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "sinon": "^22.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "genson-js": "^0.0.8",
    "yaml": "^2.9.0"
  }
}
