{
  "name": "json-schema-preview",
  "displayName": "json-schema-preview",
  "description": "Preview JSON Schema documents inside VSCode.",
  "version": "0.1.0",
  "galleryBanner": {
    "color": "#4a4a4a",
    "theme": "dark"
  },
  "license": "Apache-2.0",
  "publisher": "samdidos",
  "author": {
    "name": "Samuel Cardinal",
    "url": "https://github.com/samdidos"
  },
  "bugs": {
    "url": "https://github.com/samdidos/vscode-json-schema-preview/issues"
  },
  "homepage": "https://github.com/samdidos/vscode-json-schema-preview/blob/master/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/samdidos/vscode-json-schema-preview.git"
  },
  "engines": {
    "vscode": "^1.66.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:yml",
    "onLanguage:yaml",
    "onLanguage:json",
    "onCommand:jsonschema.preview"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsonschema.preview",
        "title": "JSON Schema: Preview",
        "icon": {
          "light": "resources/icons/open-preview_black.svg",
          "dark": "resources/icons/open-preview_white.svg"
        }
      },
      {
        "command": "jsonschema.configure",
        "title": "JSON Schema: Configure Preview",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "(resourceLangId == json || resourceLangId == yaml) && jsonschema.isJsonSchema",
          "command": "jsonschema.preview",
          "group": "navigation"
        },
        {
          "when": "(resourceLangId == json || resourceLangId == yaml) && jsonschema.isJsonSchema",
          "command": "jsonschema.configure",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "jsonschema.preview"
        },
        {
          "command": "jsonschema.configure"
        }
      ],
      "editor/context": [],
      "keybindings": []
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "test": "",
    "generate:assets": "",
    "bump:version": "npm --no-git-tag-version --allow-same-version version $VERSION"
  },
  "devDependencies": {
    "@json-editor/json-editor": "^1.17.0",
    "@types/glob": "^7.2.0",
    "@types/mocha": "^9.1.1",
    "@types/node": "14.x",
    "@types/vscode": "^1.66.0",
    "@typescript-eslint/eslint-plugin": "^5.21.0",
    "@typescript-eslint/parser": "^5.21.0",
    "@vscode/test-electron": "^2.1.3",
    "ajv": "^8.11.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.14.0",
    "genson-js": "0.0.8",
    "glob": "^8.0.1",
    "mocha": "^11.1.0",
    "ts-loader": "^9.2.8",
    "typescript": "^4.6.4",
    "webpack": "^5.70.0",
    "webpack-cli": "^4.9.2"
  }
}
